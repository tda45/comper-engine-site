CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
*.cmake

# IDE dosyaları
.vs/
.vscode/
*.vcxproj*
*.sln
*.code-workspace

# Log dosyaları
*.log
comper_debug.log

# Geçici dosyalar
*.tmp
*.temp
*~
.DS_Store
Thumbs.db

# Kullanıcı özel dosyaları (Template'deki değişiklikler)
