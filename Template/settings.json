{
  "//": "Comper Engine Tarayıcı Konfigürasyon Dosyası",
  "//": "Bu dosyayı düzenleyerek kendi tarayıcınızı özelleştirebilirsiniz",
  
  "browser_info": {
    "//": "Burayı kendi tarayıcı adınızla değiştirin",
    "name": "Benim Tarayıcım",
    "version": "1.0.0",
    "//": "Buraya kendi tarayıcı açıklamanızı yazın",
    "description": "Comper Engine tabanlı kişisel tarayıcım"
  },
  
  "window": {
    "title": "Benim Tarayıcım",
    "width": 1200,
    "height": 800,
    "resizable": true,
    "fullscreen": false
  },
  
  "theme": {
    "//": "Gece Kırmızısı varsayılan tema - renkleri istediğiniz gibi değiştirin",
    "background": "#050505",
    "accent": "#E60000",
    "text": "#FFFFFF",
    "button_background": "#282828",
    "button_hover": "#3C3C3C",
    "//": "Ek tema seçenekleri: 'dark', 'light', 'blue', 'green'",
    "preset": "night_red"
  },
  
  "navigation": {
    "//": "Tarayıcının açılış sayfası",
    "homepage": "https://www.google.com",
    "//": "Yeni sekme açıldığında gösterilecek sayfa",
    "new_tab_page": "file:///Template/new_tab.html",
    "//": "Arama motoru URL'si - %s yerine arama terimi gelecek",
    "search_engine": "https://www.google.com/search?q=%s"
  },
  
  "ui_elements": {
    "//": "Ara çubuğunu göster/gizle",
    "show_address_bar": true,
    "//": "İleri/Geri butonlarını göster/gizle",
    "show_navigation_buttons": true,
    "//": "Sekmeleri göster/gizle",
    "show_tabs": true,
    "//": "İndirme yöneticisini göster/gizle",
    "show_downloads": true,
    "//": "Geçmişi göster/gizle",
    "show_history": true,
    "//": "Yer imleri çubuğunu göster/gizle",
    "show_bookmarks": true
  },
  
  "features": {
    "//": "DevTools Inspector'ı otomatik olarak etkinleştir",
    "enable_devtools": true,
    "//": "Sağ tık menüsünü etkinleştir",
    "enable_context_menu": true,
    "//": "JavaScript desteği (gelecek için)",
    "enable_javascript": false,
    "//": "CSS desteği (basit)",
    "enable_css": true,
    "//": "Çerezleri etkinleştir",
    "enable_cookies": true,
    "//": "Pop-up engelleme",
    "block_popups": true
  },
  
  "security": {
    "//": "HTTPS-only modu",
    "https_only": false,
    "//": "Üçüncü parti çerezleri engelle",
    "block_third_party_cookies": false,
    "//": "Konum izinleri",
    "allow_location": false,
    "//": "Kamera ve mikrofon izinleri",
    "allow_camera_microphone": false
  },
  
  "performance": {
    "//": "Aynı anda açılabilecek maksimum sekme sayısı",
    "max_tabs": 50,
    "//": "Önbellek boyutu (MB)",
    "cache_size_mb": 100,
    "//": "Geçmiş kayıt süresi (gün)",
    "history_days": 30,
    "//": "Resimleri otomatik yükle",
    "auto_load_images": true
  },
  
  "customization": {
    "//": "Buraya kendi logo dosyanızın adını yazın (Template klasöründe olmalı)",
    "logo_file": "logo.png",
    "//": "Buton ikonları klasörü",
    "icons_folder": "icons",
    "//": "Kullanıcı CSS dosyası",
    "custom_css": "custom_styles.css",
    "//": "Kullanıcı JavaScript dosyası",
    "custom_js": "custom_scripts.js"
  },
  
  "//": "Geliştirici ayarları - bunları değiştirmeyin unless you know what you're doing",
  "developer": {
    "debug_mode": false,
    "console_logging": true,
    "file_logging": false,
    "log_file": "comper_debug.log"
  }
}
